{
  "manifest_version": 3,
  "name": "Chip Fact Checker",
  "version": "2.0.0",
  "description": "One-click fact-checking for Reddit, Facebook, Twitter, and more with current news grounding",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.reddit.com/*",
    "https://reddit.com/*",
    "https://facebook.com/*",
    "https://www.facebook.com/*",
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.reddit.com/*", "https://reddit.com/*"],
      "js": ["platforms/reddit.js"],
      "css": ["styles.css"]
    },
    {
      "matches": ["https://facebook.com/*", "https://www.facebook.com/*"],
      "js": ["platforms/facebook.js"],
      "css": ["styles.css"]
    },
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["platforms/twitter.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chip Fact Checker"
  }
}
